# ── QRIVARA backend configuration ───────────────────────────────────────────
# Copy to `.env` and fill in. NEVER commit the real .env (it is gitignored).
# All keys are read server-side ONLY and are never returned to the frontend.

APP_NAME="QRIVARA API"
# development = interactive /docs enabled, demo auth. Set to "production" to
# hide docs and require Supabase JWTs.
ENVIRONMENT=development

# ── Database ─────────────────────────────────────────────────────────────────
# Dev default is SQLite (no DATABASE_URL needed). For Postgres:
#   postgresql://USER:PASSWORD@HOST:5432/DBNAME
# In docker-compose this is injected automatically (points at the `db` service).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/qrivara

# ── Scaling knobs ────────────────────────────────────────────────────────────
# Worker processes (uvicorn). Set to ~2×CPU cores. Default 4 if unset.
WEB_CONCURRENCY=4
# Per-worker Postgres pool. CLUSTER TOTAL = WEB_CONCURRENCY × (POOL_SIZE+MAX_OVERFLOW)
# must stay under the DB's max_connections (default 100). 4×(10+5)=60 is safe.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
# Simulation execution. Leave false for single-process dev (API runs jobs
# in-process). Set true to offload to the `app.worker` process (docker-compose
# runs one); requires Postgres. The worker claims jobs FOR UPDATE SKIP LOCKED.
SIM_WORKER_ENABLED=false
WORKER_POLL_INTERVAL=1.0
# Max transmons the 2-D FEM solver processes per layout (capacitance/LOM/EPR/
# eigenmode/crosstalk). Bigger layouts simulate the first N and report "N of M".
MAX_FEM_QUBITS=16

# ── CORS ─────────────────────────────────────────────────────────────────────
# JSON array of allowed frontend origins. Add your deployed frontend URL.
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:4173"]

# ── Auth (production) ────────────────────────────────────────────────────────
# Leave empty for dev (demo user). Set to your Supabase project's JWT secret to
# verify real user tokens in production.
SUPABASE_JWT_SECRET=

# ── AI assistant LLM keys (optional) ─────────────────────────────────────────
# The assistant tries providers in latency-first order: Groq -> Gemini ->
# OpenRouter, with automatic fallback. Provide at least one for AI features.
# ROTATE any key that has been shared in chat/logs before going to production.
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ── QRIVARA frontend build configuration ─────────────────────────────────────
# Copy to `.env` (or set in your host's build env vars). Vite inlines VITE_*
# vars at BUILD time, so set this before `npm run build`.

# Base URL of the deployed backend API. Leave unset for local dev (defaults to
# http://localhost:8000). Example for production:
#   VITE_API_BASE=https://api.qrivara.example.com
VITE_API_BASE=
